{
  "name": "ataraxia-infrastructure",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "ataraxia": "bin/ataraxia.ts"
  },
  "scripts": {
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:dev": "cdk deploy --all -c environment=dev --require-approval never",
    "deploy:staging": "cdk deploy --all -c environment=staging --require-approval never",
    "deploy:prod": "cdk deploy --all -c environment=prod --require-approval never",
    "destroy": "cdk destroy --all"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "aws-cdk": "^2.160.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  }
}
