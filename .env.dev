# Ataraxia Frontend Configuration - dev Environment
# Generated by CDK deployment on Sat Jan 31 22:26:19 PST 2026

# Authentication Configuration
VITE_USE_COGNITO=true
VITE_ENABLE_AUTH_FALLBACK=false
VITE_AUTH_PROVIDER_TYPE=cognito
VITE_USE_API_FIRST=true

# AWS Cognito Configuration — ap-south-1 (same region/pool as backend-initial)
# Source of truth: backend-initial SSM /shared/cognito/* and /shared/api-gateway/*
VITE_AWS_REGION=ap-south-1
VITE_COGNITO_USER_POOL_ID=ap-south-1_KaAJ3JWpR
VITE_COGNITO_CLIENT_ID=25rr1ttl8rm3cv65nv2sqfh1bs
# Hosted UI for federated Google sign-in (domain prefix from the pool).
VITE_COGNITO_HOSTED_UI_DOMAIN=iraguplus-dev
# Must be registered as a callback URL on the app client (backend backlog for localhost).
VITE_COGNITO_REDIRECT_URI=http://localhost:3001/callback

# API Configuration — shared HTTP API Gateway (NO stage prefix; routes live at root)
# Serves backend-initial (no /api prefix) + billing_payment (/api/* prefix).
VITE_API_BASE_URL=https://pi4qs5lpn5.execute-api.ap-south-1.amazonaws.com
VITE_API_URL=https://pi4qs5lpn5.execute-api.ap-south-1.amazonaws.com
VITE_API_TIMEOUT=30000

# video-service backend (LiveKit rooms/tokens/transcripts). Separate deployment.
# TODO: set to the deployed video-service URL when available.
VITE_VIDEO_API_BASE_URL=

# Environment Configuration
VITE_NODE_ENV=dev
VITE_LOG_LEVEL=debug

# Feature Flags
VITE_ENABLE_MIGRATION_MODE=false
VITE_SHOW_AUTH_DEBUG=true
VITE_ENABLE_UNIVERSAL_AUTH=true

# Healthcare Platform Configuration
VITE_PLATFORM_NAME="Ataraxia Healthcare"
VITE_PLATFORM_VERSION="2.0.0"
VITE_COMPLIANCE_MODE="HIPAA"
